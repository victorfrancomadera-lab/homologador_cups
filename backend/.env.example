# Copia este archivo como .env para desarrollo local.
# En Railway, define estas variables en el panel "Variables" del servicio.

# Base de datos. En local puedes dejar SQLite (por defecto).
# En Railway, agrega un servicio PostgreSQL y referencia su variable:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL=sqlite:///./cups_local.db

# Clave para firmar los tokens JWT. GENERA UNA ALEATORIA EN PRODUCCION:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=cambia-esta-clave-por-una-aleatoria-larga

# Superadministrador inicial (se crea automaticamente la primera vez).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambia-esta-contrasena
ADMIN_EMAIL=admin@tudominio.com
ADMIN_FULL_NAME=Administrador

# Origenes permitidos para CORS (separa por comas). "*" permite todos.
# Como el frontend se sirve desde el mismo backend, "*" es seguro aqui.
CORS_ORIGINS=*

# Duracion del token en minutos (opcional, por defecto 480 = 8 horas)
# ACCESS_TOKEN_EXPIRE_MINUTES=480
